# Backend-specific .dockerignore

# Node.js dependencies (will be installed in container)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (should be provided at runtime)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git
.git/
.gitignore

# Docker files (not needed in build context)
Dockerfile
.dockerignore
docker-compose.yml

# Documentation (not needed in production)
README.md
*.md
docs/
DOCKER_DEPLOYMENT.md

# Test files
test/
tests/
*.test.js
*.spec.js
**/*.test.js
**/*.spec.js

# Development files
nodemon.json
.env.example
env.example

# Build artifacts and cache
.nyc_output/
coverage/
dist/
build/
.cache/

# Logs (will be created at runtime)
logs/
*.log

# Uploads directory (will be created at runtime, can be mounted as volume)
uploads/

# Frontend-related files (backend-only containerization)
../frontend/
../client/
../Mobile/

# Temporary files
tmp/
temp/
*.tmp


